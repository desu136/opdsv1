generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(uuid())
  name          String?
  email         String?       @unique
  phone         String?       @unique
  password      String?
  emailVerified DateTime?
  role          Role          @default(CUSTOMER)
  status        AccountStatus @default(PENDING_REVIEW)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  image         String?
  isNewUser     Boolean       @default(true)
  lastLat       Float?
  lastLng       Float?
  addresses     Address[]
  deliveries    Delivery[]
  orders        Order[]
  pharmacy      Pharmacy?
}

model Address {
  id        String  @id @default(uuid())
  userId    String
  country   String  @default("Ethiopia")
  city      String
  subCity   String
  street    String?
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])

  @@index([userId], map: "Address_userId_fkey")
}

model Pharmacy {
  id                 String        @id @default(uuid())
  ownerId            String        @unique
  name               String
  email              String        @unique
  phone              String
  address            String?
  logoUrl            String?
  coverImageUrl      String?
  description        String?       @db.Text
  workingHours       String?
  licenseNumber      String        @unique
  licenseDocumentUrl String?
  status             AccountStatus @default(PENDING_REVIEW)
  createdAt          DateTime      @default(now())
  lat                Float?
  lng                Float?
  orders             Order[]
  owner              User          @relation(fields: [ownerId], references: [id])
  inventory          Product[]
  offers             Offer[]
}

model Offer {
  id          String   @id @default(uuid())
  pharmacyId  String
  productId   String
  title       String
  discountPct Float
  startDate   DateTime
  endDate     DateTime
  imageUrl    String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  pharmacy    Pharmacy @relation(fields: [pharmacyId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])

  @@index([pharmacyId], map: "Offer_pharmacyId_fkey")
  @@index([productId], map: "Offer_productId_fkey")
}

model Product {
  id                   String      @id @default(uuid())
  pharmacyId           String
  name                 String
  category             String
  description          String?
  price                Float
  stock                Int
  requiresPrescription Boolean     @default(false)
  imageUrl             String?
  createdAt            DateTime    @default(now())
  orderItems           OrderItem[]
  pharmacy             Pharmacy    @relation(fields: [pharmacyId], references: [id])
  offers               Offer[]

  @@index([pharmacyId], map: "Product_pharmacyId_fkey")
}

model Order {
  id              String        @id @default(uuid())
  customerId      String
  pharmacyId      String
  status          OrderStatus   @default(PENDING)
  totalAmount     Float
  shippingAddress String?
  lat             Float?
  lng             Float?
  phone           String?
  notes           String?
  paymentMethod   String        @default("COD")
  createdAt       DateTime      @default(now())
  delivery        Delivery?
  customer        User          @relation(fields: [customerId], references: [id])
  pharmacy        Pharmacy      @relation(fields: [pharmacyId], references: [id])
  items           OrderItem[]
  prescription    Prescription?

  @@index([customerId], map: "Order_customerId_fkey")
  @@index([pharmacyId], map: "Order_pharmacyId_fkey")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId], map: "OrderItem_orderId_fkey")
  @@index([productId], map: "OrderItem_productId_fkey")
}

model Prescription {
  id          String             @id @default(uuid())
  orderId     String             @unique
  documentUrl String
  status      PrescriptionStatus @default(PENDING_REVIEW)
  notes       String?
  order       Order              @relation(fields: [orderId], references: [id])
}

model Delivery {
  id           String         @id @default(uuid())
  orderId      String         @unique
  agentId      String?
  status       DeliveryStatus @default(PENDING)
  pickupTime   DateTime?
  deliveryTime DateTime?
  agent        User?          @relation(fields: [agentId], references: [id])
  order        Order          @relation(fields: [orderId], references: [id])

  @@index([agentId], map: "Delivery_agentId_fkey")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

enum Role {
  CUSTOMER
  PHARMACIST
  DELIVERY_AGENT
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum PrescriptionStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
}
